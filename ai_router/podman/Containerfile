# Set 069 S4 - the Podman model-authored-probe cage image (graduated from the
# pre-Set-069 spike's Containerfile). Operator-authored, NO embedded secrets.
#
# The cage only needs an interpreter to run a model-authored probe that imports
# the code under review from the READ-ONLY /repo mount (PYTHONPATH=/repo is set on
# the `podman run` argv by ai_router.podman_sandbox, not here) and drives a real
# public entrypoint. ai_router is dependency-light, so the slim base suffices; a
# consumer repo with runtime deps adds its pinned deps here.
#
# DIGEST-PINNING (proposal sec 3.2/3.5 - a hard production requirement): build or
# pull this image ONCE and reference it BY DIGEST at runtime. Two layers:
#   1. Pin the BASE here:   FROM python@sha256:<digest>
#      (resolve once with `podman image inspect python:3.11-slim --format
#       '{{.Digest}}'` after a trusted pull, then paste it).
#   2. Pin the BUILT image at runtime: pass podman_sandbox a `name@sha256:...`
#      ref, not a bare tag. ai_router.podman_sandbox.image_is_digest_pinned()
#      flags an un-pinned ref so the producer warns.
# A bare tag is allowed ONLY for the spike / local dev. Built once, reused across
# all probes - NEVER rebuilt per probe (per-build layer churn is the Docker bloat
# failure mode the operator called out); an intentional image bump is followed by
# a prune of the now-dangling layers.
FROM python:3.11-slim

# A non-root user (rootless Podman already maps to an unprivileged host user; this
# is belt-and-suspenders so a probe cannot rely on being root inside the cage).
RUN useradd --create-home --uid 10001 probe
USER probe
WORKDIR /scratch

# No ENTRYPOINT: ai_router.podman_sandbox supplies the full probe argv
# (python -B -c "<model-authored body>").
CMD ["python", "-c", "print('pull-probe image OK')"]
